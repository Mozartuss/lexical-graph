{
  "compilerOptions": {
    "target": "ES2022",
    "allowJs": true,
    "module": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "rootDir": "./src",
    "outDir": "./dist",
    "skipLibCheck": true,
    "removeComments": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noEmit": false,
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    "src/client"
  ],
  "include": [
    "src/**/*",
    "src/*"
  ]
}
